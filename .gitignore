# ─────────────────────────────────────────────────────────────────────────────
# Dependencies — installed from package-lock.json, never committed (huge + OS-specific)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─────────────────────────────────────────────────────────────────────────────
# Secrets / environment — THESE CONTAIN YOUR AWS, STRIPE & DB CREDENTIALS.
# Never commit them. The *.example files (templates, no secrets) ARE committed.
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Build output — generated by `npm run build`, reproducible, not source
# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────────────────
# Logs & debug
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Caches & coverage
# ─────────────────────────────────────────────────────────────────────────────
.cache/
.vite/
coverage/
.eslintcache

# ─────────────────────────────────────────────────────────────────────────────
# Prisma — local SQLite/migration artifacts (the schema itself IS committed)
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.db-journal

# ─────────────────────────────────────────────────────────────────────────────
# Uploads / transcode scratch — local temp media, never source
# ─────────────────────────────────────────────────────────────────────────────
uploads/
tmp/
*.tmp

# ─────────────────────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code — keep shared project settings, ignore your personal/local ones
# ─────────────────────────────────────────────────────────────────────────────
.claude/settings.local.json
