# Root .env — read by docker-compose.yml (compose-level variables only).
# Copy to ".env" ON THE SERVER and fill in. This file is committed; .env is NOT.
#
# Backend SECRETS (DATABASE_URL, JWT, AWS, Stripe SECRET) go in server/.env — NOT here.

# Postgres credentials for the database container
POSTGRES_USER=bingely
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=bingely

# Stripe PUBLISHABLE key (safe to expose; baked into the frontend at build time)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
