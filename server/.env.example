# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://bingely:bingely@localhost:5432/bingely?schema=public

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── S3 ─────────────────────────────────────────────────────────────────────
S3_RAW_BUCKET=raw-bingely-media
S3_TRANSCODED_BUCKET=transcode-bingely-media
PRESIGNED_URL_EXPIRY=900

# ── SQS ────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=

# ── CloudFront (CDN in front of the transcoded bucket; no https://, no slash) ─
CLOUDFRONT_DOMAIN=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_SUCCESS_URL=http://localhost:5173/account?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/plans

# ── Seed admin (used by `npm run db:seed`) ────────────────────────────────────
SEED_ADMIN_EMAIL=admin@bingely.local
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Bingely Admin
