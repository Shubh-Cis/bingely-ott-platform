{
  "name": "bingely-server",
  "version": "1.0.0",
  "description": "Bingely OTT platform — API + transcode worker (Express, Prisma, PostgreSQL, S3, SQS, FFmpeg)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/transcode.worker.js",
    "worker:dev": "nodemon src/workers/transcode.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "setup:cors": "node scripts/setup-cors.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-sqs": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1070.0",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "stripe": "^17.7.0",
    "uuid": "^14.0.0",
    "zod": "^3.24.1"
